// Prisma Schema — punto de verdad del modelo de datos.
// Cada vez que lo modifiques, ejecuta: npx prisma migrate dev --name <descripcion>

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum AccountType {
  CHECKING      // Cuenta corriente
  SAVINGS       // Cuenta de ahorros
  CREDIT_CARD   // Tarjeta de crédito
  DIGITAL_WALLET // Nequi, Daviplata, Dale
  INVESTMENT    // CDT, fondos, acciones
  CASH          // Efectivo / caja menor
  LOAN          // Crédito / deuda
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionOwner {
  PERSONAL
  BUSINESS
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  ANNUAL
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ProductType {
  PRODUCT   // Producto físico (tiene inventario)
  SERVICE   // Servicio (sin inventario)
}

// ─── MÓDULO CORE: USUARIOS ────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  password      String
  phone         String?
  avatarUrl     String?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relaciones módulo personal
  accounts      Account[]
  budgets       Budget[]
  goals         Goal[]
  bills         Bill[]

  // Relaciones módulo empresa
  businesses    Business[]

  @@map("users")
}

// ─── MÓDULO PERSONAL: CUENTAS ─────────────────────────────────────────────────

model Account {
  id            String      @id @default(uuid())
  userId        String
  name          String      // "Bancolombia Ahorros", "Nequi", etc.
  type          AccountType
  balance       Decimal     @default(0) @db.Decimal(15, 2)
  currency      String      @default("COP")
  color         String?     // Color para la UI
  icon          String?     // Icono para la UI
  isManual      Boolean     @default(true)  // false = conectada via Open Banking
  externalId    String?     // ID en Belvo u otro proveedor
  lastSyncedAt  DateTime?
  isArchived    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]

  @@map("accounts")
}

// ─── MÓDULO PERSONAL + EMPRESA: CATEGORÍAS ────────────────────────────────────

model Category {
  id            String    @id @default(uuid())
  name          String
  icon          String?
  color         String?
  isDefault     Boolean   @default(false)  // true = categoría del sistema
  userId        String?                    // null = categoría global del sistema
  parentId      String?                    // Para subcategorías

  parent        Category?   @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children      Category[]  @relation("CategoryHierarchy")
  transactions  Transaction[]

  @@map("categories")
}

// ─── MÓDULO PERSONAL + EMPRESA: TRANSACCIONES ────────────────────────────────

model Transaction {
  id            String           @id @default(uuid())
  accountId     String?
  categoryId    String?
  businessId    String?          // Si es una transacción empresarial
  type          TransactionType
  owner         TransactionOwner @default(PERSONAL)
  amount        Decimal          @db.Decimal(15, 2)
  description   String?
  categoryLabel String?          // Categoría como texto libre (empresas)
  notes         String?
  date          DateTime
  isRecurring   Boolean          @default(false)
  recurringId   String?          // Agrupa transacciones recurrentes
  receiptUrl    String?          // Foto del recibo (OCR)
  externalId    String?          // ID en banco/Belvo
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  account       Account?         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category      Category?        @relation(fields: [categoryId], references: [id])
  business      Business?        @relation(fields: [businessId], references: [id])

  @@index([accountId, date])
  @@index([businessId, date])
  @@map("transactions")
}

// ─── MÓDULO PERSONAL: PRESUPUESTOS ────────────────────────────────────────────

model Budget {
  id            String       @id @default(uuid())
  userId        String
  categoryId    String?
  name          String
  amount        Decimal      @db.Decimal(15, 2)
  period        BudgetPeriod @default(MONTHLY)
  startDate     DateTime
  endDate       DateTime?
  alertAt       Int          @default(80)  // Alerta al X% del límite
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("budgets")
}

// ─── MÓDULO PERSONAL: METAS DE AHORRO ────────────────────────────────────────

model Goal {
  id            String     @id @default(uuid())
  userId        String
  name          String
  targetAmount  Decimal    @db.Decimal(15, 2)
  currentAmount Decimal    @default(0) @db.Decimal(15, 2)
  deadline      DateTime?
  icon          String?
  color         String?
  status        GoalStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

// ─── MÓDULO PERSONAL: FACTURAS RECURRENTES ───────────────────────────────────

model Bill {
  id            String    @id @default(uuid())
  userId        String
  name          String    // "Arriendo", "Netflix", "Internet"
  amount        Decimal   @db.Decimal(15, 2)
  dueDay        Int       // Día del mes que vence (1-31)
  categoryId    String?
  isActive      Boolean   @default(true)
  lastPaidAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bills")
}

// ─── MÓDULO EMPRESA ───────────────────────────────────────────────────────────

model Business {
  id            String    @id @default(uuid())
  userId        String
  name          String
  nit           String?   // NIT de la empresa
  legalName     String?
  logoUrl       String?
  address       String?
  phone         String?
  email         String?
  taxRegime     String?   // "SIMPLE" | "ORDINARIO"
  isActive       Boolean   @default(true)
  usePriceLists  Boolean   @default(false) // Activa listas de precios
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  customers     Customer[]
  invoices      Invoice[]
  products      Product[]
  priceLists    PriceList[]

  @@map("businesses")
}

// ─── MÓDULO EMPRESA: CLIENTES (CRM básico) ───────────────────────────────────

model Customer {
  id            String    @id @default(uuid())
  businessId    String
  name          String
  nit           String?   // NIT o cédula
  email         String?
  phone         String?
  address       String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  business      Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  priceList     PriceList? @relation(fields: [priceListId], references: [id])
  priceListId   String?
  invoices      Invoice[]

  @@map("customers")
}

// ─── MÓDULO EMPRESA: FACTURAS ─────────────────────────────────────────────────

model Invoice {
  id            String        @id @default(uuid())
  businessId    String
  customerId    String?
  number        String        // Número de factura
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  subtotal      Decimal       @db.Decimal(15, 2)
  tax           Decimal       @default(0) @db.Decimal(15, 2)
  total         Decimal       @db.Decimal(15, 2)
  notes         String?
  pdfUrl        String?
  dianCufe      String?       // Código DIAN para factura electrónica
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      Customer?     @relation(fields: [customerId], references: [id])
  items         InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id            String   @id @default(uuid())
  invoiceId     String
  productId     String?  // Referencia opcional al catálogo
  description   String
  quantity      Decimal  @db.Decimal(10, 3)
  unitPrice     Decimal  @db.Decimal(15, 2)
  total         Decimal  @db.Decimal(15, 2)
  taxRate       Decimal  @default(0) @db.Decimal(5, 2)

  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product       Product?  @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

// ─── MÓDULO EMPRESA: PRODUCTOS Y SERVICIOS ────────────────────────────────────

model Product {
  id             String      @id @default(uuid())
  businessId     String
  name           String
  description    String?
  type           ProductType @default(PRODUCT)
  sku            String?     // Código interno del producto
  price          Decimal     @db.Decimal(15, 2)   // Precio de venta base
  cost           Decimal?    @db.Decimal(15, 2)   // Costo para calcular margen
  taxRate        Decimal     @default(19) @db.Decimal(5, 2) // IVA %
  unit           String      @default("unidad")   // unidad, kg, hora, mes...
  trackInventory Boolean     @default(false)       // Solo PRODUCT type
  stock          Decimal     @default(0) @db.Decimal(10, 3)
  minStock       Decimal?    @db.Decimal(10, 3)   // Alerta de stock mínimo
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoiceItems    InvoiceItem[]
  priceListItems  PriceListItem[]

  @@index([businessId, isActive])
  @@map("products")
}

// ─── MÓDULO EMPRESA: LISTAS DE PRECIOS ───────────────────────────────────────

model PriceList {
  id          String   @id @default(uuid())
  businessId  String
  name        String   // "Minorista", "Mayorista", "Especial"
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items       PriceListItem[]
  customers   Customer[]

  @@map("price_lists")
}

model PriceListItem {
  id          String   @id @default(uuid())
  priceListId String
  productId   String
  price       Decimal  @db.Decimal(15, 2)

  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId])
  @@map("price_list_items")
}
