# ─── Base de datos ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:CAMBIA_PASSWORD@localhost:5432/finanzas

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── JWT — genera un secret con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRET_DE_32_CHARS_MINIMO
JWT_EXPIRES_IN=7d

# ─── Webhooks Open Banking ────────────────────────────────────────────────────
WEBHOOK_SECRET=CAMBIA_ESTO_POR_UN_SECRET_SEGURO
NEQUI_WEBHOOK_SECRET=CAMBIA_ESTO_POR_UN_SECRET_SEGURO

# ─── Email Ingestion (IMAP) ───────────────────────────────────────────────────
# Deja EMAIL_HOST vacío para desactivar la ingesta automática por correo.
#
# Gmail:
#   1. Activa la verificación en 2 pasos en tu cuenta Google.
#   2. Ve a https://myaccount.google.com/apppasswords
#   3. Genera una "Contraseña de aplicación" → úsala como EMAIL_PASSWORD.
#   4. Activa IMAP en Gmail: Configuración → Ver toda la configuración → Reenvío e IMAP
#
# Outlook / Hotmail:
#   EMAIL_HOST=outlook.office365.com
#   EMAIL_PORT=993
#
# El servicio solo procesa correos con remitentes de dominios bancarios
# conocidos (nequi.com.co, bancolombia.com.co) y los marca como LEÍDO
# inmediatamente para evitar duplicados.
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=tucuenta@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_MAILBOX=INBOX
