generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums — Plan y Equipo ───────────────────────────────────────────────────

enum PlanType {
  FREE
  PRO
  EMPRESA
}

enum MemberRole {
  EDITOR
  VIEWER
}

// ─── Enums — Módulo Personal ──────────────────────────────────────────────────

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  CASH
}

enum InvestmentType {
  ETF
  STOCK
  CRYPTO
}

enum InvTransactionType {
  BUY
  SELL
}

// ─── Enums — Módulo Empresarial ───────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  INVOICED
}

enum ProductType {
  PRODUCT
  SERVICE
}

enum PurchaseStatus {
  DRAFT
  RECEIVED
  PAID
  CANCELLED
}

// ─── Usuario (compartido) ─────────────────────────────────────────────────────

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  plan          PlanType  @default(FREE)
  planExpiresAt DateTime?
  planStartedAt DateTime?

  // Módulo personal
  bankAccounts BankAccount[]
  transactions Transaction[]
  categories   Category[]
  savingsGoals SavingsGoal[]
  investments  Investment[]

  // Módulo empresarial
  businesses       Business[]
  businessMembers  BusinessMember[]

  // Integración de correo
  emailIntegration EmailIntegration?

  @@map("users")
}

// ─── Integración de correo por usuario ───────────────────────────────────────

model EmailIntegration {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailUser     String
  emailPassword String
  emailHost     String   @default("imap.gmail.com")
  emailPort     Int      @default(993)
  emailMailbox  String   @default("INBOX")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("email_integrations")
}

// ─── Módulo Personal: Cuentas ─────────────────────────────────────────────────

model BankAccount {
  id                String        @id @default(uuid())
  name              String
  type              AccountType
  balance           Float         @default(0.0)
  currency          String        @default("COP")
  provider          String?
  externalAccountId String?
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("bank_accounts")
}

// ─── Módulo Personal: Categorías ─────────────────────────────────────────────

model Category {
  id           String        @id @default(uuid())
  name         String
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([name, userId])
  @@map("categories")
}

// ─── Módulo Personal: Transacciones ──────────────────────────────────────────

model Transaction {
  id            String          @id @default(uuid())
  amount        Float
  description   String
  type          TransactionType
  date          DateTime        @default(now())
  bankAccountId String
  bankAccount   BankAccount     @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  categoryId    String
  category      Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now())

  @@map("transactions")
}

// ─── Módulo Personal: Metas de Ahorro ────────────────────────────────────────

model SavingsGoal {
  id            String    @id @default(uuid())
  name          String
  targetAmount  Float
  currentAmount Float     @default(0.0)
  deadline      DateTime?
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("savings_goals")
}

// ─── Módulo Personal: Inversiones ────────────────────────────────────────────

model Investment {
  id           String                  @id @default(uuid())
  ticker       String
  name         String
  type         InvestmentType
  shares       Float                   @default(0.0)
  averagePrice Float                   @default(0.0)
  userId       String
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  history      InvestmentTransaction[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([ticker, userId])
  @@map("investments")
}

model InvestmentTransaction {
  id            String             @id @default(uuid())
  type          InvTransactionType
  shares        Float
  pricePerShare Float
  fee           Float              @default(0.0)
  date          DateTime           @default(now())
  investmentId  String
  investment    Investment         @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@map("investment_transactions")
}

// ─── Módulo Empresarial: Empresa ──────────────────────────────────────────────

model Business {
  id            String    @id @default(uuid())
  userId        String
  name          String
  nit           String?
  legalName     String?
  currency      String    @default("COP")
  logoUrl       String?
  address       String?
  phone         String?
  email         String?
  taxRegime     String?   // "SIMPLE" | "ORDINARIO"
  isActive      Boolean   @default(true)
  usePriceLists Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  customers     Customer[]
  invoices      Invoice[]
  products      Product[]
  priceLists    PriceList[]
  quotes        Quote[]
  suppliers     Supplier[]
  purchases     Purchase[]
  bizTransactions BizTransaction[]
  members       BusinessMember[]
  invites       BusinessInvite[]

  @@map("businesses")
}

// ─── Módulo Empresarial: Clientes ─────────────────────────────────────────────

model Customer {
  id          String    @id @default(uuid())
  businessId  String
  name        String
  nit         String?
  email       String?
  phone       String?
  address     String?
  notes       String?
  priceListId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business    Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  priceList   PriceList? @relation(fields: [priceListId], references: [id])
  invoices    Invoice[]
  quotes      Quote[]

  @@map("customers")
}

// ─── Módulo Empresarial: Facturas ─────────────────────────────────────────────

model Invoice {
  id          String        @id @default(uuid())
  businessId  String
  customerId  String?
  number      String
  status      InvoiceStatus @default(DRAFT)
  issueDate   DateTime      @default(now())
  dueDate     DateTime?
  subtotal    Float
  tax         Float         @default(0)
  total       Float
  notes       String?
  pdfUrl      String?
  dianCufe    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer    Customer?     @relation(fields: [customerId], references: [id])
  items       InvoiceItem[]
  quote       Quote?

  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Float
  unitPrice   Float
  total       Float
  taxRate     Float    @default(0)

  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product?  @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

// ─── Módulo Empresarial: Productos y Servicios ───────────────────────────────

model Product {
  id             String      @id @default(uuid())
  businessId     String
  name           String
  description    String?
  type           ProductType @default(PRODUCT)
  sku            String?
  price          Float
  cost           Float?
  taxRate        Float       @default(19)
  unit           String      @default("unidad")
  trackInventory Boolean     @default(false)
  stock          Float       @default(0)
  minStock       Float?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoiceItems    InvoiceItem[]
  priceListItems  PriceListItem[]
  quoteItems      QuoteItem[]
  purchaseItems   PurchaseItem[]

  @@index([businessId, isActive])
  @@map("products")
}

// ─── Módulo Empresarial: Listas de Precios ───────────────────────────────────

model PriceList {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items       PriceListItem[]
  customers   Customer[]

  @@map("price_lists")
}

model PriceListItem {
  id          String   @id @default(uuid())
  priceListId String
  productId   String
  price       Float

  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId])
  @@map("price_list_items")
}

// ─── Módulo Empresarial: Cotizaciones ────────────────────────────────────────

model Quote {
  id          String      @id @default(uuid())
  businessId  String
  customerId  String?
  invoiceId   String?     @unique
  number      String
  status      QuoteStatus @default(DRAFT)
  validUntil  DateTime?
  notes       String?
  subtotal    Float
  tax         Float       @default(0)
  total       Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer    Customer?   @relation(fields: [customerId], references: [id])
  invoice     Invoice?    @relation(fields: [invoiceId], references: [id])
  items       QuoteItem[]

  @@map("quotes")
}

model QuoteItem {
  id          String   @id @default(uuid())
  quoteId     String
  productId   String?
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float    @default(0)
  total       Float

  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@map("quote_items")
}

// ─── Módulo Empresarial: Proveedores ─────────────────────────────────────────

model Supplier {
  id          String    @id @default(uuid())
  businessId  String
  name        String
  nit         String?
  email       String?
  phone       String?
  address     String?
  contactName String?
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business    Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  purchases   Purchase[]

  @@index([businessId, isActive])
  @@map("suppliers")
}

// ─── Módulo Empresarial: Órdenes de Compra ───────────────────────────────────

model Purchase {
  id          String         @id @default(uuid())
  businessId  String
  supplierId  String?
  number      String
  status      PurchaseStatus @default(DRAFT)
  issueDate   DateTime       @default(now())
  dueDate     DateTime?
  subtotal    Float
  tax         Float          @default(0)
  total       Float
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  business    Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier    Supplier?      @relation(fields: [supplierId], references: [id])
  items       PurchaseItem[]

  @@map("purchases")
}

model PurchaseItem {
  id          String   @id @default(uuid())
  purchaseId  String
  productId   String?
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float    @default(0)
  total       Float

  purchase    Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product     Product?  @relation(fields: [productId], references: [id])

  @@map("purchase_items")
}

// ─── Módulo Empresarial: Transacciones de Empresa ────────────────────────────
// Separado del modelo personal Transaction para no romper lógica existente.

model BizTransaction {
  id            String          @id @default(uuid())
  businessId    String
  type          TransactionType
  amount        Float
  description   String
  categoryLabel String?
  date          DateTime        @default(now())
  createdAt     DateTime        @default(now())

  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, date])
  @@map("biz_transactions")
}

// ─── Módulo Empresarial: Equipo ───────────────────────────────────────────────

model BusinessMember {
  id         String     @id @default(uuid())
  businessId String
  userId     String
  role       MemberRole
  title      String?
  invitedAt  DateTime   @default(now())

  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@map("business_members")
}

model BusinessInvite {
  id         String     @id @default(uuid())
  businessId String
  email      String
  role       MemberRole
  title      String?
  token      String     @unique
  expiresAt  DateTime
  usedAt     DateTime?

  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_invites")
}
